# application-local.yml.example
# 이 파일을 복사해서 application-local.yml 로 만들고 실제 값 채우기
# application-local.yml 은 절대 git 커밋 금지 (.gitignore 등록됨)

spring:
  jpa:
    hibernate:
      ddl-auto: update   # 로컬에서만 update 사용
    show-sql: true

DB_URL: jdbc:postgresql://<supabase-host>:5432/postgres
DB_USERNAME: postgres
DB_PASSWORD: your-db-password

JWT_SECRET: your-local-jwt-secret-min-32-chars

OPENAI_API_KEY: sk-...
CLAUDE_API_KEY: sk-ant-...

SUPABASE_URL: https://your-project.supabase.co
SUPABASE_KEY: your-supabase-anon-key
